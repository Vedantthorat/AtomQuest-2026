{
  "rules": {
    "users": {
      "$userId": {
        // Users can read their own profile
        ".read": "auth != null && auth.uid == $userId",
        // Users can update their own profile
        ".write": "auth != null && auth.uid == $userId"
      }
    },
    "goals": {
      ".read": "auth != null",
      "$goalId": {
        // Employees can read/write their own goals
        ".write": "auth != null && (
          data.child('ownerId').val() == auth.uid ||
          get(/databases/$(database)/documents/users/$(auth.uid)/role).data.role in ['MANAGER', 'ADMIN']
        )"
      }
    },
    "activities": {
      ".read": "auth != null",
      "$activityId": {
        ".write": "auth != null"
      }
    },
    "notifications": {
      "$notificationId": {
        // Users can only read their own notifications
        ".read": "auth != null && data.child('userId').val() == auth.uid",
        // Only system can create notifications
        ".write": "auth != null"
      }
    },
    "escalations": {
      ".read": "auth != null",
      "$escalationId": {
        ".write": "auth != null && (
          get(/databases/$(database)/documents/users/$(auth.uid)/role).data.role in ['MANAGER', 'ADMIN']
        )"
      }
    },
    "departments": {
      ".read": "auth != null",
      "$departmentId": {
        ".write": "auth != null && get(/databases/$(database)/documents/users/$(auth.uid)/role).data.role == 'ADMIN'"
      }
    },
    "cycles": {
      ".read": "auth != null",
      "$cycleId": {
        ".write": "auth != null && get(/databases/$(database)/documents/users/$(auth.uid)/role).data.role == 'ADMIN'"
      }
    }
  }
}